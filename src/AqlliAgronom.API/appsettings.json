{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=aqlliagronom;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_256BIT_KEY_IN_PRODUCTION",
    "Issuer": "AqlliAgronom",
    "Audience": "AqlliAgronom.Clients",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Claude": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY",
    "ModelId": "claude-opus-4-6",
    "MaxTokens": 4096,
    "Temperature": 0.3,
    "MaxRetries": 3,
    "RetryDelayMs": 1000
  },
  "Embedding": {
    "ApiKey": "YOUR_VOYAGE_AI_API_KEY",
    "BaseUrl": "https://api.voyageai.com",
    "ModelId": "voyage-3",
    "VectorDimension": 1024
  },
  "Qdrant": {
    "Host": "localhost",
    "Port": 6334,
    "ApiKey": null,
    "KnowledgeCollectionName": "agronomic_knowledge",
    "VectorDimension": 1024
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "AqlliAgronom:",
    "DefaultExpiryMinutes": 60
  },
  "Telegram": {
    "BotToken": "YOUR_TELEGRAM_BOT_TOKEN",
    "WebhookUrl": null,
    "WebhookSecret": null,
    "AdminChatId": null,
    "UseWebhook": false
  },
  "FileStorage": {
    "BasePath": "/app/uploads",
    "BaseUrl": "https://yourdomain.com/uploads"
  },
  "Seed": {
    "AdminPassword": "Admin@12345",
    "AdminTelegramChatId": 913025694
  },
  "Cors": {
    "AllowedOrigins": [
      "https://yourdomain.com",
      "https://admin.yourdomain.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aqlliagronom-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  }
}
